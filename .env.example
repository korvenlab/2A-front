# Browser / SSR publishable key only — never commit real secrets.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# URL canónica da app (links de recuperação de senha). Deve estar em Supabase → Auth → URL Configuration → Redirect URLs.
# VITE_APP_URL=https://2avendas.com

# Opcional: URL da landing após "Sair" (default = mesmo origin da app, ex. https://2avendas.com).
# VITE_PUBLIC_HOME_URL=https://2avendas.com

# Payment Link Stripe (página /assinatura). Default no código se vazio. Envia client_reference_id=orgId:userId (quem paga = usuário logado).
# VITE_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/seu_link
